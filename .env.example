TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION_PATH=/data/session/telegram.session
WATCH_MODE=saved_messages
WATCH_CHAT_ID=
ALLOWED_USER_IDS=
RCLONE_REMOTE=gdrive
RCLONE_BASE_PATH=UPLOADS
DEFAULT_UPLOAD_DIRECTORY=DOWNLOADS
REMOTE_FOLDER_PATTERN=
REMOTE_COLLISION_POLICY=rename
DOWNLOAD_DIR=/data/downloads
STATE_DIR=/data/state
LOG_DIR=/data/logs
RCLONE_CONFIG_PATH=/config/rclone/rclone.conf
MAX_CONCURRENT_JOBS=1
QUEUE_MAX_SIZE=20
MAX_FILE_SIZE_GB=0
MIN_FREE_DISK_GB=5
PROGRESS_UPDATE_INTERVAL_SECONDS=5
TELEGRAM_DOWNLOAD_CONNECTIONS=2
PARALLEL_DOWNLOAD_MIN_SIZE_MB=64
RCLONE_TRANSFERS=1
RCLONE_CHECKERS=2
RCLONE_RETRIES=5
RCLONE_LOW_LEVEL_RETRIES=10
RCLONE_RETRIES_SLEEP_SECONDS=10
RCLONE_STATS_INTERVAL_SECONDS=2
RCLONE_DRIVE_CHUNK_SIZE=32Mi
RCLONE_UPLOAD_TIMEOUT_MINUTES=180
RCLONE_EXTRA_ARGS=
DELETE_LOCAL_AFTER_SUCCESS=true
DELETE_PARTIAL_ON_FAILURE=false
FAILED_FILE_RETENTION_HOURS=24
CLEANUP_INTERVAL_MINUTES=30
RETRY_INTERRUPTED_JOBS=true
GENERATE_PUBLIC_LINK=false
LOG_LEVEL=INFO
LOG_FILE=/data/logs/uploader.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
